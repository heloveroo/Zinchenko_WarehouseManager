<Application x:Class="WarehouseManager.WpfApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WarehouseManager.ViewModels;assembly=WarehouseManager.ViewModels"
             xmlns:pages="clr-namespace:WarehouseManager.WpfApp.Pages"
             xmlns:conv="clr-namespace:WarehouseManager.WpfApp.Converters">
    <Application.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <conv:LocationConverter x:Key="LocationConv"/>
        <conv:CategoryConverter x:Key="CategoryConv"/>

        <DataTemplate DataType="{x:Type vm:WarehousesViewModel}">
			<pages:WarehouseListPage />
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:WarehouseDetailViewModel}">
			<pages:WarehouseDetailPage />
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:ProductDetailViewModel}">
			<pages:ProductDetailPage />
		</DataTemplate>

		<SolidColorBrush x:Key="PrimaryBrush"       Color="#1E3A5F"/>
		<SolidColorBrush x:Key="AccentBrush"        Color="#2E86AB"/>
		<SolidColorBrush x:Key="BackgroundBrush"    Color="#F4F6F9"/>
		<SolidColorBrush x:Key="CardBrush"          Color="#FFFFFF"/>
		<SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1A1A2E"/>
		<SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
		<SolidColorBrush x:Key="BorderBrush"        Color="#E5E7EB"/>

		<Style x:Key="BackButtonStyle" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource AccentBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontSize"        Value="14"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>

		<Style x:Key="WarehouseListItemStyle" TargetType="Border">
			<Setter Property="Background"      Value="{StaticResource CardBrush}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Padding"         Value="16,12"/>
			<Setter Property="Margin"          Value="0,0,0,10"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>

		<Style x:Key="CategoryTagStyle" TargetType="Border">
			<Setter Property="Background"   Value="#EBF4FF"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding"      Value="8,3"/>
		</Style>

	</Application.Resources>
</Application>