<UserControl x:Class="WarehouseManager.WpfApp.Pages.ProductDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
	<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="24,20,24,24">

				<!-- Навігація + кнопки -->
				<Grid Margin="0,0,0,16">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<Button Grid.Column="0"
                            Content="← Назад до складу"
                            Style="{StaticResource BackButtonStyle}"
                            Command="{Binding GoBackCommand}"/>

					<!-- Кнопка редагувати — тільки в режимі перегляду -->
					<Button Grid.Column="2" Content="✏ Редагувати"
                            Command="{Binding EditProductCommand}"
                            Padding="12,6" FontSize="13"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White" BorderThickness="0" Cursor="Hand">
						<Button.Style>
							<Style TargetType="Button">
								<Setter Property="Visibility" Value="Visible"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsEditing}" Value="True">
										<Setter Property="Visibility" Value="Collapsed"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Button.Style>
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
							</ControlTemplate>
						</Button.Template>
					</Button>

					<!-- Кнопки режиму редагування — тільки коли редагуємо -->
					<StackPanel Grid.Column="2" Orientation="Horizontal"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
						<Button Content="✔ Зберегти"
                                Command="{Binding SaveCommand}"
                                Padding="12,6" FontSize="13" Margin="0,0,8,0"
                                Background="#388E3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>
						<Button Content="✖ Скасувати"
                                Command="{Binding CancelEditCommand}"
                                Padding="12,6" FontSize="13"
                                Background="#757575" Foreground="White"
                                BorderThickness="0" Cursor="Hand">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</Grid>

				<!-- ══ РЕЖИМ ПЕРЕГЛЯДУ ══════════════════════════════════════ -->

				<!-- Шапка товару -->
				<Border Background="{StaticResource AccentBrush}"
                        CornerRadius="12" Padding="22,18" Margin="0,0,0,16">
					<Border.Style>
						<Style TargetType="Border">
							<Setter Property="Visibility" Value="Visible"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsEditing}" Value="True">
									<Setter Property="Visibility" Value="Collapsed"/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Border.Style>
					<Border.Effect>
						<DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Color="#000000"/>
					</Border.Effect>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0">
                            <Border Background="White" CornerRadius="4"
								Padding="8,3" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Product.Category, Converter={StaticResource CategoryConv}}"
								FontSize="12" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="{Binding Product.Name}"
                                       FontSize="21" FontWeight="Bold"
                                       Foreground="White" TextWrapping="Wrap" Margin="0,8,20,0"/>
						</StackPanel>
						<StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
							<TextBlock Text="Загальна вартість"
                                       FontSize="11" Foreground="#CCFFFFFF" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding Product.TotalPrice, StringFormat={}{0:N2} ₴}"
                                       FontSize="24" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Right" Margin="0,4,0,0"/>
						</StackPanel>
					</Grid>
				</Border>

                <!-- Поля перегляду -->
                <Grid Margin="0,0,0,16">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0"
            Style="{StaticResource WarehouseListItemStyle}" Margin="0,0,8,10">
                        <StackPanel>
                            <TextBlock Text="🔢  ID товару" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Product.Id}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1"
            Style="{StaticResource WarehouseListItemStyle}" Margin="8,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🏭  ID складу" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Product.WarehouseId}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0"
            Style="{StaticResource WarehouseListItemStyle}" Margin="0,0,8,10">
                        <StackPanel>
                            <TextBlock Text="📦  Кількість на складі" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Product.Quantity, StringFormat='{}{0} шт.'}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1"
            Style="{StaticResource WarehouseListItemStyle}" Margin="8,0,0,10">
                        <StackPanel>
                            <TextBlock Text="💰  Ціна за одиницю" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Product.UnitPrice, StringFormat={}{0:N2} ₴}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0"
            Style="{StaticResource WarehouseListItemStyle}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="🏭  Склад" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Product.WarehouseName}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="1"
            Style="{StaticResource WarehouseListItemStyle}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="🏷️  Категорія" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Product.Category, Converter={StaticResource CategoryConv}}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Опис -->
				<Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,14"
                        Margin="0,0,0,16">
					<Border.Style>
						<Style TargetType="Border">
							<Setter Property="Visibility" Value="Visible"/>
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsEditing}" Value="True">
									<Setter Property="Visibility" Value="Collapsed"/>
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Border.Style>
					<StackPanel>
						<TextBlock Text="📋  Опис / Характеристики" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
						<TextBlock Text="{Binding Product.Description}"
                                   FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" LineHeight="22"/>
					</StackPanel>
				</Border>

				<!-- ══ РЕЖИМ РЕДАГУВАННЯ ════════════════════════════════════ -->
				<Border Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="20,16"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="130"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="30"/>
							<ColumnDefinition Width="130"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="12"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="12"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="12"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Grid.Row="0" Grid.Column="0" Text="Назва:"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
						<TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                                 Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>

						<TextBlock Grid.Row="2" Grid.Column="0" Text="Категорія:"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding EditCategory}"
                                  Padding="8,6" FontSize="13">      
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CategoryConv}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Кількість (шт.):"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
						<TextBox Grid.Row="2" Grid.Column="4"
                                 Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>

						<TextBlock Grid.Row="4" Grid.Column="0" Text="Ціна / шт. (₴):"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
						<TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding EditUnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>

						<TextBlock Grid.Row="4" Grid.Column="3" Text="Загальна вартість:"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
						<TextBlock Grid.Row="4" Grid.Column="4"
                                   Text="{Binding EditTotalPrice, StringFormat={}{0:N2} ₴}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>

						<TextBlock Grid.Row="6" Grid.Column="0" Text="Опис:"
                                   FontWeight="SemiBold" VerticalAlignment="Top"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
						<TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="4"
                                 Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="70" VerticalScrollBarVisibility="Auto"/>
					</Grid>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<!-- Оверлей завантаження -->
		<Grid Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
				<ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{StaticResource AccentBrush}"/>
				<TextBlock Text="Збереження..." Foreground="White"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>