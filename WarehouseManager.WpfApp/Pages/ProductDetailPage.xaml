<Page x:Class="WarehouseManager.WpfApp.Pages.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}"
      Title="Деталі товару">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- ── Кнопка "Назад" ── -->
            <Button Content="← Назад до складу"
                    Style="{StaticResource BackButtonStyle}"
                    Click="OnBackClick"
                    Margin="0,0,0,16"/>

            <!-- ── Шапка товару ── -->
            <Border Background="{StaticResource AccentBrush}"
                    CornerRadius="12"
                    Padding="22,18"
                    Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8"
                                      Opacity="0.15" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Назва і категорія -->
                    <StackPanel Grid.Column="0">
                        <Border Background="#FFFFFF22" CornerRadius="4"
                                Padding="8,3" HorizontalAlignment="Left">
                            <TextBlock x:Name="CategoryText"
                                       FontSize="12"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock x:Name="ProductNameText"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,8,20,0"/>
                        <TextBlock x:Name="ProductIdText"
                                   FontSize="12"
                                   Foreground="#CCFFFFFF"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Загальна вартість -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock Text="Загальна вартість"
                                   FontSize="11"
                                   Foreground="#CCFFFFFF"
                                   HorizontalAlignment="Right"/>
                        <TextBlock x:Name="TotalPriceText"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Поля у 2 колонки ── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Кількість -->
                <Border Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource WarehouseListItemStyle}"
                        Margin="0,0,8,10">
                    <StackPanel>
                        <TextBlock Text="📦  Кількість на складі"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="QuantityText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ціна за одиницю -->
                <Border Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource WarehouseListItemStyle}"
                        Margin="8,0,0,10">
                    <StackPanel>
                        <TextBlock Text="💰  Ціна за одиницю"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="UnitPriceText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ID складу -->
                <Border Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource WarehouseListItemStyle}"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="🏭  ID складу"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="WarehouseIdText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Категорія -->
                <Border Grid.Row="1" Grid.Column="1"
                        Style="{StaticResource WarehouseListItemStyle}"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🏷️  Категорія"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CategoryDetailText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Опис товару ── -->
            <Border Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14">
                <StackPanel>
                    <TextBlock Text="📋  Опис / Характеристики"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="DescriptionText"
                               FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
