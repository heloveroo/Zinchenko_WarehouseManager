<UserControl x:Class="WarehouseManager.WpfApp.Pages.WarehouseDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Рядок 0: Назад + кнопки редагування -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Назад до складів"
                    Style="{StaticResource BackButtonStyle}"
                    Command="{Binding GoBackCommand}"/>

            <!-- Кнопки перегляду -->
            <!-- Кнопка перегляду — показується коли НЕ редагуємо -->
            <Button Grid.Column="2"
        Content="✏ Редагувати склад"
        Command="{Binding EditWarehouseCommand}"
        Padding="12,6" FontSize="13"
        Background="{StaticResource AccentBrush}"
        Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Кнопки режиму редагування -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                <Button Content="✔ Зберегти"
                        Command="{Binding SaveWarehouseCommand}"
                        Padding="12,6" FontSize="13" Margin="0,0,8,0"
                        Background="#388E3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="✖ Скасувати"
                        Command="{Binding CancelEditCommand}"
                        Padding="12,6" FontSize="13"
                        Background="#757575" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Рядок 1: Картка складу (перегляд) -->
        <Border Grid.Row="1"
                Background="{StaticResource PrimaryBrush}"
                CornerRadius="12" Padding="20,16" Margin="0,0,0,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Warehouse.Name}"
               FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <Border Background="Transparent" BorderBrush="White" BorderThickness="1" CornerRadius="4"
            Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Warehouse.Id, StringFormat='ID: {0}'}"
                   FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="📍 " FontSize="13" Foreground="#B0C4DE"/>
                        <TextBlock Text="{Binding Warehouse.Location, Converter={StaticResource LocationConv}}"
                                   FontSize="13" Foreground="#B0C4DE"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Загальна вартість"
                               FontSize="12" Foreground="#B0C4DE" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Warehouse.TotalValue, StringFormat={}{0:N2} ₴}"
                               FontSize="22" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Рядок 2: Форма редагування -->
        <Border Grid.Row="2"
                Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="20,16" Margin="0,0,0,16"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Назва:"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" FontSize="13"/>

                <TextBlock Grid.Column="3" Text="Місто:"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox Grid.Column="4"
          ItemsSource="{Binding Locations}"
          SelectedItem="{Binding EditLocation}"
          Padding="8,6" FontSize="13">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource LocationConv}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Рядок 3: Пошук + сортування товарів -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding ProductSearch, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,6" FontSize="13"
                     BorderBrush="{StaticResource BorderBrush}"
                     Margin="0,0,8,0">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍  Пошук товарів..."
                                                           Foreground="#9E9E9E" Margin="10,6"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}"
                      Padding="8,6" FontSize="13" Margin="0,0,8,0"/>

            <CheckBox Grid.Column="2"
                      Content="За спаданням"
                      IsChecked="{Binding SortDescending}"
                      VerticalAlignment="Center" FontSize="12"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,0,8,0"/>

            <Button Grid.Column="3"
                    Content="+ Додати товар"
                    Command="{Binding AddProductCommand}"
                    Padding="12,6" FontSize="13"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Рядок 4: Список товарів -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredProducts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource WarehouseListItemStyle}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="5"
                                                  Opacity="0.05" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Border Style="{StaticResource CategoryTagStyle}">
                                            <TextBlock Text="{Binding Category, Converter={StaticResource CategoryConv}}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="{Binding Quantity, StringFormat=' • {0} шт.'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            HorizontalAlignment="Right" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N2} ₴}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N2} ₴/шт.}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Відкрити"
                                        Command="{Binding DataContext.SelectProductCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Id}"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="White" BorderThickness="0"
                                        Padding="10,4" FontSize="12"
                                        Cursor="Hand" Margin="0,0,8,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Grid.Column="3"
                                        Content="🗑"
                                        Command="{Binding DataContext.DeleteProductCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="16" Cursor="Hand"
                                        ToolTip="Видалити товар"
                                        VerticalAlignment="Center"/>        
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Рядок 5: Порожній склад -->
        <Border Grid.Row="4"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="24">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FilteredProducts.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="Товарів не знайдено"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Оверлей завантаження -->
        <Grid Grid.RowSpan="6" Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Завантаження..." Foreground="White"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>