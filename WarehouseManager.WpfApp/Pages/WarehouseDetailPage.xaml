<Page x:Class="WarehouseManager.WpfApp.Pages.WarehouseDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}"
      Title="Деталі складу">

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <!-- Кнопка "Назад" -->
            <RowDefinition Height="Auto"/>
            <!-- Картка з інформацією про склад -->
            <RowDefinition Height="Auto"/>
            <!-- Заголовок списку товарів -->
            <RowDefinition Height="Auto"/>
            <!-- Список товарів -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Кнопка "Назад" ── -->
        <Button Grid.Row="0"
                Content="← Назад до складів"
                Style="{StaticResource BackButtonStyle}"
                Click="OnBackClick"
                Margin="0,0,0,16"/>

        <!-- ── Картка з деталями складу ── -->
        <Border Grid.Row="1"
                Background="{StaticResource PrimaryBrush}"
                CornerRadius="12"
                Padding="20,16"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Назва, місто, кількість товарів -->
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="WarehouseNameText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="📍 "
                                   FontSize="13"
                                   Foreground="#B0C4DE"/>
                        <TextBlock x:Name="WarehouseLocationText"
                                   FontSize="13"
                                   Foreground="#B0C4DE"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="🆔 ID: "
                                   FontSize="13"
                                   Foreground="#B0C4DE"/>
                        <TextBlock x:Name="WarehouseIdText"
                                   FontSize="13"
                                   Foreground="#B0C4DE"/>
                    </StackPanel>
                </StackPanel>

                <!-- Загальна вартість -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Загальна вартість"
                               FontSize="12"
                               Foreground="#B0C4DE"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TotalValueText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Заголовок списку товарів ── -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock x:Name="ProductsHeaderText"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- ── Список товарів / повідомлення про порожній склад ── -->
        <Grid Grid.Row="3">
            <!-- Повідомлення коли складу порожній -->
            <Border x:Name="EmptyPanel"
                    Visibility="Collapsed"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="24">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="📭"
                               FontSize="36"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="На цьому складі немає товарів"
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Список товарів -->
            <ScrollViewer x:Name="ProductsScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ProductList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Tag="{Binding}"
                                    Click="OnProductClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch"
                                    Cursor="Hand">
                                <Border Style="{StaticResource WarehouseListItemStyle}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="5"
                                                          Opacity="0.05" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Назва і категорія -->
                                        <StackPanel Grid.Column="0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <Border Style="{StaticResource CategoryTagStyle}">
                                                    <TextBlock Text="{Binding Category}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="{Binding Quantity, StringFormat=' • {0} шт.'}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Загальна вартість -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,0,12,0">
                                            <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:C}}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:C}/шт.}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <!-- Стрілка -->
                                        <TextBlock Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
