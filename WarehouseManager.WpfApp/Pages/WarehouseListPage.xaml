<Page x:Class="WarehouseManager.WpfApp.Pages.WarehouseListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}"
      Title="Список складів">

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <!-- Заголовок сторінки -->
            <RowDefinition Height="Auto"/>
            <!-- Кількість знайдених складів -->
            <RowDefinition Height="Auto"/>
            <!-- Список складів (прокручується) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Заголовок ── -->
        <TextBlock Grid.Row="0"
                   Text="Склади"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,4"/>

        <!-- ── Підпис з кількістю ── -->
        <TextBlock Grid.Row="1"
                   x:Name="SubtitleText"
                   FontSize="14"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- ── Список складів ── -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WarehouseList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Картка складу — клікабельна через Button-обгортку -->
                        <Button Tag="{Binding}"
                                Click="OnWarehouseClick"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalContentAlignment="Stretch"
                                Cursor="Hand">
                            <Border Style="{StaticResource WarehouseListItemStyle}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1"
                                                      BlurRadius="6"
                                                      Opacity="0.06"
                                                      Color="#000000"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Іконка -->
                                        <ColumnDefinition Width="48"/>
                                        <!-- Назва і місто -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Стрілка -->
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Іконка складу -->
                                    <Border Grid.Column="0"
                                            Width="40" Height="40"
                                            CornerRadius="8"
                                            Background="#EBF4FF"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="🏭"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Назва та місто -->
                                    <StackPanel Grid.Column="1"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Location}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Стрілка навігації -->
                                    <TextBlock Grid.Column="2"
                                               Text="›"
                                               FontSize="22"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
